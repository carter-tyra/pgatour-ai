{
  "name": "pgatour-ai",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.4.1",
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "pnpm --filter @pgatour-ai/web dev",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "e2e": "playwright test",
    "lint": "biome check .",
    "format": "biome check --write .",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm build"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.8",
    "@playwright/test": "^1.60.0",
    "@types/node": "25.9.1",
    "drizzle-kit": "0.31.10",
    "turbo": "2.9.14",
    "typescript": "6.0.3",
    "vitest": "4.1.7"
  }
}
