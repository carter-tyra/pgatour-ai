{
  "name": "@pgatour-ai/ingest",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit",
    "db:wait": "tsx src/cli/db-wait.ts",
    "data:quality": "tsx src/cli/data-quality.ts",
    "data:repair-result-fields": "tsx src/cli/repair-result-field-entries.ts",
    "data:status": "tsx src/cli/data-status.ts",
    "ingest:balldontlie:history": "tsx src/cli/ball-dont-lie-history.ts",
    "ingest:balldontlie:seed": "tsx src/cli/ball-dont-lie-seed.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1053.0",
    "@pgatour-ai/config": "workspace:*",
    "@pgatour-ai/db": "workspace:*",
    "@pgatour-ai/domain": "workspace:*",
    "@pgatour-ai/providers": "workspace:*",
    "drizzle-orm": "0.45.2",
    "postgres": "3.4.9",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "25.9.1",
    "tsx": "^4.22.3",
    "typescript": "6.0.3",
    "vitest": "4.1.7"
  }
}
